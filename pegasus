        plat.Anchored = true; plat.CanCollide = true; plat.Transparency = 0.3
        plat.Parent = workspace
        RunService.Heartbeat:Wait()
        local _flyTok = newCarpetCancelToken()
        carpetFly(hrp, airPos, { speed = 195, safetyPad = 0, ignoreList = { plat }, cancelToken = _flyTok })
        for i = 1, 5 do
            if Player:GetAttribute("Stealing") then break end
            hrp.Velocity = Vector3.new(hrp.Velocity.X, 0, hrp.Velocity.Z); hrp.CFrame = CFrame.new(airPos)
            task.wait(0.05)
        end
        task.spawn(function()
            local start = tick()
            while tick() - start < 20 do
                if Player:GetAttribute("Stealing") then break end
                task.wait(0.1)
            end
            plat:Destroy()
        end)
    elseif verticalDiff > 2 then
        local airPos = _clampRideY(Vector3.new(hrp.Position.X, bestPart.Position.Y - 6.5, hrp.Position.Z), bestPart)
        local plat = Instance.new("Part")
        plat.Name = "XiTempPlatform"; plat.Size = Vector3.new(3, 1, 3)
        plat.Position = airPos - Vector3.new(0, 4, 0)
        plat.Color = Color3.new(1, 0, 0); plat.Material = Enum.Material.Neon
        plat.Anchored = true; plat.CanCollide = true; plat.Transparency = 0.3
        plat.Parent = workspace
        RunService.Heartbeat:Wait()
        local _flyTok = newCarpetCancelToken()
        carpetFly(hrp, airPos, { speed = 195, safetyPad = 0, ignoreList = { plat }, cancelToken = _flyTok })
        for i = 1, 5 do
            if Player:GetAttribute("Stealing") then break end
            hrp.Velocity = Vector3.new(hrp.Velocity.X, 0, hrp.Velocity.Z)
            hrp.CFrame = CFrame.new(airPos)
            task.wait(0.05)
        end
        task.spawn(function()
            local start = tick()
            while tick() - start < 20 do
                if Player:GetAttribute("Stealing") then break end
                task.wait(0.1)
            end
            plat:Destroy()
        end)
    else
        local reachPos = _clampRideY(bestPart.Position, bestPart)
        local _flyTok = newCarpetCancelToken()
        carpetFly(hrp, reachPos, { speed = 210, safetyPad = 0, cancelToken = _flyTok })
        for i = 1, 10 do
