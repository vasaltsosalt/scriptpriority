        Round(bindBadge, 8)
        Gradient(bindBadge, {
            ColorSequenceKeypoint.new(0, Color3.fromRGB(150, 45, 255)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(42, 24, 105)),
        }, 25)
        Stroke(bindBadge, 2.5, HAZE.STROKE, 0.05)
        -- coolvisual style: animated stroke only
    end
    control.BackgroundColor3 = Color3.fromRGB(55, 34, 125)
    control.BackgroundTransparency = 0.45
    control.BorderSizePixel = 0
    control.AutoButtonColor = false
    control.Font = Enum.Font.GothamBold
    control.TextSize = 11
    control.TextColor3 = HAZE.TEXT
    control.TextXAlignment = Enum.TextXAlignment.Center
    control.TextYAlignment = Enum.TextYAlignment.Center
    CoolTextGradient(control)
    Round(control, 999)
    local controlGrad = Gradient(control, {
        ColorSequenceKeypoint.new(0, Color3.fromRGB(150, 45, 255)),
        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(95, 48, 190)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(35, 20, 90)),
    }, 25)
    FX:registerFlowing(controlGrad, 18)
    Stroke(control, 2.5, HAZE.STROKE_ON, 0.05)

    local knob
    if isToggle then
        knob = Instance.new("Frame", control)
        knob.Size = UDim2.fromOffset(20, 20)
        knob.Position = UDim2.fromOffset(3, 3)
        knob.BackgroundColor3 = HAZE.TEXT
        knob.BorderSizePixel = 0
        Round(knob, 999)
        Stroke(knob, 2.5, HAZE.STROKE_ON, 0.05)
    end

    local isOn = false
    local function refresh()
        local bindName = bindBadge and (Binds[actionName] and Binds[actionName].Name or "---") or ""
        if isOn then
            Tween(card, { BackgroundColor3 = Color3.fromRGB(70, 34, 150), BackgroundTransparency = 0.45 }, TWEEN_SNAP)
            cardStroke.Color = HAZE.STROKE_ON
            cardStroke.Transparency = 0.12
            accentStrip.BackgroundTransparency = 1
            nameLabel.TextColor3 = HAZE.ACCENT2
            cardGrad.Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0, Color3.fromRGB(185, 86, 255)),
                ColorSequenceKeypoint.new(0.45, Color3.fromRGB(95, 48, 190)),
                ColorSequenceKeypoint.new(1, Color3.fromRGB(40, 18, 95)),
            })
            controlGrad.Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0, Color3.fromRGB(185, 86, 255)),
                ColorSequenceKeypoint.new(0.5, Color3.fromRGB(150, 45, 255)),
                ColorSequenceKeypoint.new(1, Color3.fromRGB(95, 48, 190)),
            })
            FX:registerBreath(cardStroke, HAZE.STROKE_ON, 0.08, 0.42, 1.8, math.random() * 6)
            if bindBadge then bindBadge.TextColor3 = HAZE.ACCENT2 end
            control.BackgroundColor3 = Color3.fromRGB(95, 48, 190)
            control.BackgroundTransparency = 0.45
            control.TextColor3 = HAZE.TEXT
            control.Text = isToggle and "" or "RUN"
            if knob then Tween(knob, { Position = UDim2.fromOffset(27, 3), BackgroundColor3 = Color3.fromRGB(255, 255, 255) }, TWEEN_SNAP) end
        else
            Tween(card, { BackgroundColor3 = Color3.fromRGB(42, 24, 105), BackgroundTransparency = 0.35 }, TWEEN_SNAP)
            cardStroke.Color = HAZE.STROKE
            cardStroke.Transparency = 0.58
            accentStrip.BackgroundTransparency = 1
            nameLabel.TextColor3 = HAZE.TEXT
            cardGrad.Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0, Color3.fromRGB(150, 45, 255)),
                ColorSequenceKeypoint.new(0.45, Color3.fromRGB(42, 24, 105)),
                ColorSequenceKeypoint.new(1, Color3.fromRGB(18, 10, 42)),
            })
            controlGrad.Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0, Color3.fromRGB(150, 45, 255)),
                ColorSequenceKeypoint.new(0.5, Color3.fromRGB(95, 48, 190)),
                ColorSequenceKeypoint.new(1, Color3.fromRGB(35, 20, 90)),
            })
            FX:removeBreath(cardStroke)
            if bindBadge then bindBadge.TextColor3 = HAZE.MUTED end
            control.BackgroundColor3 = Color3.fromRGB(55, 34, 125)
            control.BackgroundTransparency = 0.45
            control.TextColor3 = HAZE.TEXT
            control.Text = isToggle and "" or "RUN"
            if knob then Tween(knob, { Position = UDim2.fromOffset(3, 3), BackgroundColor3 = HAZE.TEXT }, TWEEN_SNAP) end
        end
        if bindBadge then bindBadge.Text = bindName end
        updateActiveCount()
    end

    refresh()

    card.MouseEnter:Connect(function()
        if not isOn then
            Tween(card, { BackgroundColor3 = Color3.fromRGB(95, 48, 190), BackgroundTransparency = 0.3 }, TWEEN_SNAP)
            Tween(cardStroke, { Transparency = 0.36 }, TWEEN_SNAP)
            Tween(accentStrip, { BackgroundTransparency = 1 }, TWEEN_SNAP)
        end
    end)
    card.MouseLeave:Connect(function()
        if not isOn then refresh() end
    end)

    control.MouseButton1Click:Connect(function()
        if instantStealLockActive and not isAllowedDuringInstantSteal(actionName) then
            if isToggle and isOn then
                isOn = false
                refresh()
                if callback then callback(false) end
                queueSaveConfig()
            end
            notify("Instant Steal Lock", "This function is disabled during Instant Steal", "warn")
            return
        end
        if isToggle then
            isOn = not isOn
            refresh()
            if callback then callback(isOn) end
            queueSaveConfig()
            notify(text, isOn and "Enabled" or "Disabled", isOn and "success" or "info")
        else
            Tween(control, { Size = control.Size - UDim2.fromOffset(4, 2) }, TWEEN_SNAP)
            task.delay(0.08, function()
                Tween(control, { Size = isToggle and UDim2.fromOffset(50, 26) or UDim2.fromOffset(72, 28) }, TWEEN_SNAP)
            end)
            if callback then callback() end
            notify(text, "Triggered", "action")
        end
    end)

	if bindBadge then
		-- binds locked
	end

    buttonStates[actionName] = {
        refresh = refresh,
        isToggle = isToggle,
        setState = function(s, silent)
            if instantStealLockActive and s and not isAllowedDuringInstantSteal(actionName) then
                s = false
                if not silent then
                    notify("Instant Steal Lock", "This function is disabled during Instant Steal", "warn")
                end
            end
            if isOn == s then return end
            isOn = s
            refresh()
            if isToggle and callback then callback(isOn) end
            if not silent then
                queueSaveConfig()
                if isToggle then
                    notify(text, isOn and "Enabled" or "Disabled", isOn and "success" or "info")
                end
            end
        end,
        getState = function()
            return isOn
        end,
    }

    cardMeta[card] = { category = category, actionName = actionName, getState = function() return isOn end }
    functionCards[#functionCards + 1] = card
    applyFilters()
    return card
end

