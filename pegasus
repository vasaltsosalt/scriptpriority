            visible[#visible + 1] = ad
        end
    end
    for _, r in ipairs(brRows) do
        returnBrRow(r)
    end
    brRows = {}
    brSelected = nil
    for i, ad in ipairs(visible) do
        local r = getBrRow()
        r.row.LayoutOrder = i
        r.nameLbl.Text = ad.name
        r.valueLbl.Text = ad.genText
        r.uid = ad.uid
        if brTargetUid == ad.uid then
