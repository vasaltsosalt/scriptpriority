-- Floating bottom-right popups. Toasts stack upward and slide/fade out.
local ToastUI = {
    container = nil,
    list = {},        -- stack of { root, fill, title, body, decayAt, removing }
    MAX = 4,
    WIDTH = 302,
    HEIGHT = 64,
    GAP = 10,
    LIFETIME = 3.8,
}

function ToastUI:ensureContainer()
    if self.container and self.container.Parent then return end
    local sg = Instance.new("ScreenGui")
    sg.Name = "PegasusDevToasts"
    sg.ResetOnSpawn = false
    sg.DisplayOrder = 9999
    sg.IgnoreGuiInset = true
    parentToSafeGui(sg)
    local cont = Instance.new("Frame")
    cont.Name = "ToastContainer"
    cont.Size = UDim2.new(0, self.WIDTH, 1, 0)
    cont.Position = UDim2.new(1, -16 - self.WIDTH, 0, 0)
    cont.BackgroundTransparency = 1
    cont.Parent = sg
    self.container = cont
end

function ToastUI:layout()
    -- Stack from bottom up: last pushed sits at the bottom.
    local y = 16
    for i = #self.list, 1, -1 do
        local t = self.list[i]
        if t.root and t.root.Parent then
            t.targetY = (i - 1) * (self.HEIGHT + self.GAP) + 16
            Tween(t.root, { Position = UDim2.new(0, 0, 1, -(t.targetY + self.HEIGHT)) }, TWEEN_FAST)
        end
    end
end

-- ToastUI.show(title, body, kind)
-- kind: "info" (purple), "success" (green), "warn" (red), "action" (cyan)
local TOAST_KIND = {
    info    = { fill = HAZE.ACCENT,  text = HAZE.ACCENT2, glow = HAZE.ACCENT },
    success = { fill = HAZE.SUCCESS, text = HAZE.SUCCESS, glow = HAZE.SUCCESS },
    warn    = { fill = HAZE.DANGER,  text = HAZE.DANGER,  glow = HAZE.DANGER },
    action  = { fill = HAZE.CYAN,    text = HAZE.CYAN,    glow = HAZE.CYAN },
}

function ToastUI:show(title, body, kind)
    self:ensureContainer()
    kind = kind or "info"
    local palette = TOAST_KIND[kind] or TOAST_KIND.info

    -- Cap the stack: remove the oldest if at max.
    while #self.list >= self.MAX do
        self:removeIndex(1, true)
    end

    local root = Instance.new("Frame")
    root.Name = "Toast"
    root.Size = UDim2.fromOffset(self.WIDTH, self.HEIGHT)
    root.Position = UDim2.new(0, 40, 1, -(16 + self.HEIGHT))
    root.BackgroundColor3 = HAZE.SURF
    root.BackgroundTransparency = 0.32
    root.BorderSizePixel = 0
    root.ClipsDescendants = true
    root.Parent = self.container
    Round(root, 14)

    local bgGrad = Gradient(root, {
        ColorSequenceKeypoint.new(0, Color3.fromRGB(20, 14, 50)),
        ColorSequenceKeypoint.new(0.55, Color3.fromRGB(12, 8, 35)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(12, 8, 35)),
    }, 105)

    -- coolvisual style: animated stroke only
    local stroke = Stroke(root, 1.2, palette.fill, 0.32)
    FX:registerBreath(stroke, palette.glow, 0.45, 0.82, 2.4, math.random() * 6)

    local bar = Instance.new("Frame", root)
    bar.Size = UDim2.new(0, 4, 1, -16)
    bar.Position = UDim2.fromOffset(8, 8)
    bar.BackgroundColor3 = palette.fill
    bar.BorderSizePixel = 0
    Round(bar, 999)
    local barGrad = Gradient(bar, {
        ColorSequenceKeypoint.new(0, palette.fill),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 255, 255)),
    }, 90)
    FX:registerFlowing(barGrad, 90)

    local icon = Instance.new("TextLabel", root)
    icon.Size = UDim2.fromOffset(26, 26)
    icon.Position = UDim2.fromOffset(20, 19)
    icon.BackgroundTransparency = 1
    icon.Font = Enum.Font.GothamBlack
    icon.TextSize = 16
    icon.TextColor3 = palette.text
    icon.TextXAlignment = Enum.TextXAlignment.Center
    icon.TextYAlignment = Enum.TextYAlignment.Center
    icon.Text = ({ info = "i", success = "+", warn = "!", action = "*" })[kind] or "i"
    CoolTextGradient(icon)

    local ttl = Instance.new("TextLabel", root)
    ttl.Size = UDim2.new(1, -66, 0, 20)
    ttl.Position = UDim2.fromOffset(54, 10)
    ttl.BackgroundTransparency = 1
    ttl.Font = Enum.Font.GothamBold
    ttl.TextSize = 12
    ttl.TextColor3 = HAZE.TEXT
    ttl.TextXAlignment = Enum.TextXAlignment.Left
    ttl.Text = title or ""
    CoolTextGradient(ttl)

    local bodyLbl = Instance.new("TextLabel", root)
    bodyLbl.Size = UDim2.new(1, -66, 0, 18)
    bodyLbl.Position = UDim2.fromOffset(54, 32)
    bodyLbl.BackgroundTransparency = 1
    bodyLbl.Font = Enum.Font.GothamMedium
    bodyLbl.TextSize = 11
    bodyLbl.TextColor3 = HAZE.DIM
    bodyLbl.TextXAlignment = Enum.TextXAlignment.Left
    bodyLbl.Text = body or ""
    CoolTextGradient(bodyLbl)

    local toast = {
        root = root, stroke = stroke, barGrad = barGrad, bgGrad = bgGrad,
        ttl = ttl, body = bodyLbl, decayAt = tick() + self.LIFETIME, removing = false,
    }
    self.list[#self.list + 1] = toast

    -- entrance
    root.BackgroundTransparency = 1
    local us = Instance.new("UIScale", root)
    us.Scale = 0.9
    Tween(root, { BackgroundTransparency = 0.32 }, TWEEN_SNAP)
    Tween(us, { Scale = 1 }, TWEEN_SPRING)

    self:layout()
end

function ToastUI:removeIndex(i, instant)
    local t = table.remove(self.list, i)
    if not t then return end
    t.removing = true
    FX:removeBreath(t.stroke)
    FX:removeFlowing(t.barGrad)
    if instant or not t.root then
        if t.root then t.root:Destroy() end
        self:layout()
        return
    end
    local us = t.root:FindFirstChildOfClass("UIScale")
    if us then
        Tween(us, { Scale = 0.92 }, TWEEN_FAST)
    end
    Tween(t.root, {
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 30, t.root.Position.Y.Scale, t.root.Position.Y.Offset),
    }, TWEEN_FAST)
    task.delay(0.18, function()
        if t.root then t.root:Destroy() end
    end)
    self:layout()
end

