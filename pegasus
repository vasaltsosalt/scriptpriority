function cascadeCards()
    local order = 0
    for _, card in ipairs(functionCards) do
        if card.Visible then
            order = order + 1
            local us = card:FindFirstChildOfClass("UIScale")
            if not us then
                us = Instance.new("UIScale", card)
            end
            us.Scale = 0.94
            card.BackgroundTransparency = 1
            card.Active = false
            local delay = (order - 1) * 0.035
            task.delay(delay, function()
                if not card.Parent then return end
                Tween(us, { Scale = 1 }, TWEEN_SPRING)
                Tween(card, { BackgroundTransparency = 0.35 }, TWEEN_FAST)
                card.Active = true
            end)
        end
    end
end

