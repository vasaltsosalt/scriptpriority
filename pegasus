-- ========== VISUAL EFFECTS ENGINE ==========
-- One render loop drives flowing gradients and breathing glows via registries,
-- so adding/removing surfaces is O(1) and we never spin up a loop per element.
local FX = {
    flowingGradients = {},   -- { gradient, speed, minRot }
    breathingGlows = {},    -- { uiStroke, color, minT, maxT, speed, phase }
    _t = 0,
}

function FX:registerFlowing(grad, speed, minRot)
    speed = speed or 40
    self.flowingGradients[grad] = { speed = speed, minRot = minRot or 0 }
    return grad
end

function FX:removeFlowing(grad)
    self.flowingGradients[grad] = nil
end

function FX:registerBreath(stroke, color, minT, maxT, speed, phase)
    self.breathingGlows[stroke] = {
        color = color or HAZE.ACCENT,
        minT = minT or 0.55,
        maxT = maxT or 0.92,
        speed = speed or 1.7,
        phase = phase or 0,
    }
    return stroke
end

function FX:removeBreath(stroke)
    self.breathingGlows[stroke] = nil
end

RunService.RenderStepped:Connect(function(dt)
    FX._t = FX._t + dt
    -- Flowing gradients
    for grad, info in pairs(FX.flowingGradients) do
        if grad and grad.Parent then
            grad.Rotation = (grad.Rotation + info.speed * dt) % 360
        else
            FX.flowingGradients[grad] = nil
        end
    end
    -- Breathing glows
    for stroke, info in pairs(FX.breathingGlows) do
        if stroke and stroke.Parent then
            local blend = (math.sin(FX._t * info.speed + info.phase) + 1) * 0.5
            stroke.Transparency = info.minT + (info.maxT - info.minT) * blend
            stroke.Color = info.color
        else
            FX.breathingGlows[stroke] = nil
        end
    end
end)

