local function isBeingFused(animalData)
    local part = findAdorneeGlobal(animalData)
    if not part then return false end
    -- Scan the part and its parents for any fusing indicators
    local scanList = {part}
    local p = part.Parent
    if p then table.insert(scanList, p) end
    if p and p.Parent then table.insert(scanList, p.Parent) end
    for _, obj in ipairs(scanList) do
        if obj then
            for _, d in ipairs(obj:GetDescendants()) do
                if d:IsA("Beam") then return true end
                if d:IsA("ParticleEmitter") and d.Enabled then return true end
                if d:IsA("Fire") or d:IsA("Sparkles") then return true end
                if d:IsA("BillboardGui") and d.Enabled then
                    local lbl = d:FindFirstChildWhichIsA("TextLabel", true)
                    if lbl then
                        local t = lbl.Text:lower()
                        if t:find("fusing") or t:find("fuse") or t:find("%d+") then return true end
                    end
                end
            end
        end
    end
    return false
end

local function runAutoSnipe()
    if TP_STATE.isMoving then return end
    local bestAnimal, bestPart = nil, nil
    local bestGen = -1

    -- Use the auto steal target if available
    if bestStealAnimal and bestStealPart then
        bestAnimal = bestStealAnimal
        bestPart = bestStealPart
        bestGen = tonumber(bestStealAnimal.genValue) or 0
    end

    if not bestAnimal then
        for _, ad in ipairs(allAnimalsCache) do
            if ad.genValue and ad.genValue >= 20000000 and not isMyPlotByName(ad.plot) and not isBeingFused(ad) then
                local p = findAdorneeGlobal(ad)
                if p then
                    local gv = tonumber(ad.genValue) or 0
                    if gv > bestGen then bestGen = gv; bestAnimal = ad; bestPart = p end
                end
            end
        end
    end
    if not bestAnimal or not bestPart then notify("TP", "No target found", "warn"); return end
    TP_STATE.isMoving = true
    task.delay(8, function() TP_STATE.isMoving = false end)

    local char = Player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum or hum.Health <= 0 then TP_STATE.isMoving = false; return end

    local exactPos = bestPart.Position
    local carpet = Player.Backpack:FindFirstChild("Flying Carpet") or char:FindFirstChild("Flying Carpet")
    if carpet then hum:EquipTool(carpet) end
    task.wait(0.01)

    local isSecondFloor = exactPos.Y > 10
    local isFloor2 = exactPos.Y > 10 and exactPos.Y <= 25

    local plotIndex = getClosestBaseIdx(exactPos)
    -- Floor 2 targets start from floor 1, then ride up on the red platform.
    -- Floor 3+ still starts from the high base route.
    local targetBasePos = (isSecondFloor and not isFloor2) and BASES_HIGH[plotIndex] or BASES_LOW[plotIndex]

    local _flyTok = newCarpetCancelToken()
    carpetFly(hrp, targetBasePos, {
        speed = (isSecondFloor and not isFloor2) and 155 or 155,
        safetyPad = 0,
        routeAroundObstacles = true,
        cancelToken = _flyTok,
    })
    hrp.Velocity = Vector3.zero
    if isSecondFloor then
        hrp.CFrame = CFrame.new(targetBasePos)
        hrp.Velocity = Vector3.zero
    end
    task.wait(0.15)

    if not isSecondFloor or isFloor2 then
        local bestSpot = CLONE_POSITIONS_FLOOR[1]
        local minDst = math.huge
        for _, v in ipairs(CLONE_POSITIONS_FLOOR) do
            local d = (bestPart.Position - v).Magnitude
            if d < minDst then minDst = d; bestSpot = v end
        end
        for _ = 1, 5 do
            hrp.Velocity = Vector3.zero; hrp.Velocity = Vector3.zero
            task.wait(0.02)
        end
        for i = 1, 6 do
            hrp.Velocity = Vector3.zero
            if (hrp.Position - bestSpot).Magnitude > 3 then
                hrp.CFrame = CFrame.new(bestSpot)
                hrp.Velocity = Vector3.zero
                task.wait(0.05)
            end
        end
    end

    local bestFace = FACE_TARGETS[1]
    local minFaceDist = math.huge
    for _, v in ipairs(FACE_TARGETS) do
        local d = (hrp.Position - v).Magnitude
        if d < minFaceDist then minFaceDist = d; bestFace = v end
    end
    task.wait(0.1)
    hrp.CFrame = CFrame.lookAt(hrp.Position, Vector3.new(bestFace.X, hrp.Position.Y, bestFace.Z))
    -- Do the clone-in step for first-floor, second-floor, and higher-floor brainrots.
    -- Walk a bit farther first so the clone has enough forward push to enter cleanly.
    local _cloneNeeded = true
    local _cloneOk = false
    if _cloneNeeded then
        hrp.Velocity = Vector3.zero; hrp.Velocity = Vector3.zero
        walkForward(2)
        task.wait(0.25)
        local _stab = os.clock()
        while os.clock() - _stab < 0.15 do
            if not (hrp and hrp.Parent) then break end
            hrp.Velocity = Vector3.zero; hrp.Velocity = Vector3.zero
            task.wait(0.03)
        end
        local _anchorYaw = hrp.CFrame.LookVector
        for attempt = 1, 3 do
            if not (hrp and hrp.Parent) then break end
            hrp.Velocity = Vector3.zero; hrp.Velocity = Vector3.zero
            local _preClonePos = hrp.Position
            instantClone(0.05)
            local cdl = tick() + 2.5
            while _G.isCloning and tick() < cdl do task.wait() end
            if _G.isCloning then _G.isCloning = false end
            local timeout = isSecondFloor and 1.5 or 4.0
            local _moveStart = os.clock()
            while os.clock() - _moveStart < timeout do
                if not (hrp and hrp.Parent) then break end
                if (hrp.Position - _preClonePos).Magnitude >= 3 then _cloneOk = true; break end
                task.wait(0.03)
            end
            if _cloneOk then break end
            if hrp and hrp.Parent then
                hrp.Velocity = Vector3.zero; hrp.Velocity = Vector3.zero
                hrp.CFrame = CFrame.lookAt(_preClonePos, _preClonePos + _anchorYaw)
                hrp.Velocity = Vector3.zero
            end
            task.wait(0.08)
        end
    end
    if _cloneNeeded and not _cloneOk then
        notify("TP", "Clone failed — aborted", "warn")
        TP_STATE.isMoving = false
        return
    end
    task.wait(0.08)
    if carpet then hum:EquipTool(carpet) end

    local verticalDiff = bestPart.Position.Y - hrp.Position.Y
    task.spawn(function() autoGrab(bestAnimal, 5) end)

    if isFloor2 then
        -- For second-floor brainrots, come from floor 1 first, then move upward on the red square.
        -- This mirrors the higher-floor platform approach but keeps the target recognized as floor 2.
        local airPos = _clampRideY(Vector3.new(hrp.Position.X, bestPart.Position.Y - 2.5, hrp.Position.Z), bestPart)
        local plat = Instance.new("Part")
        plat.Name = "XiTempPlatform"; plat.Size = Vector3.new(3, 1, 3)
