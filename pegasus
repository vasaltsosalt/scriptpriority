            if not podiums then return nil, nil, nil end
            local podium = podiums:FindFirstChild(animalData.slot)
            if not podium then return nil, nil, nil end
            local base = podium:FindFirstChild("Base")
            if not base then return nil, nil, nil end
            local spawn = base:FindFirstChild("Spawn")
            if not spawn then return nil, nil, nil end
            local d = (spawn.Position - hrp.Position).Magnitude
            if d <= STEAL_RADIUS then
                local att = spawn:FindFirstChild("PromptAttachment")
