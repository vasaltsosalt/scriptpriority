-- ========== CONFIG SAVE/LOAD ==========
local CONFIG_PATH = "pegasusdev_config.json"
local configSaveQueued = false

local KEY_NAME_LOOKUP = {}
do
    for _, key in pairs(Enum.KeyCode:GetEnumItems()) do
        KEY_NAME_LOOKUP[key.Name] = key
    end
end

local function saveConfig()
    if not writefile then return end
    local data = {
        toggles = {},
        binds = {},
        invisSettings = InvisSettings,
        version = 1,
    }
    for name, s in pairs(buttonStates) do
        if s.isToggle and s.getState then
            data.toggles[name] = s.getState()
        end
    end
    for action, key in pairs(Binds) do
        data.binds[action] = key.Name
    end
    local ok, json = pcall(HttpService.JSONEncode, HttpService, data)
    if ok and json then
        pcall(writefile, CONFIG_PATH, json)
    end
end

local function queueSaveConfig()
    configSaveQueued = true
    pcall(saveConfig)
end

local function loadConfig()
    if not readfile then return {} end
    if isfile and not isfile(CONFIG_PATH) then return {} end
    local ok, content = pcall(readfile, CONFIG_PATH)
    if not ok or not content or content == "" then return {} end
    local ok, data = pcall(HttpService.JSONDecode, HttpService, content)
    if not ok or type(data) ~= "table" then return {} end
    if data.toggles then
        for name, state in pairs(data.toggles) do
            local s = buttonStates[name]
            if s and s.isToggle and s.setState then
                s.setState(state, true)
            end
        end
    end
    if data.binds then
        for action, keyName in pairs(data.binds) do
            if action == "AutoBat" then
                keyName = "H"
            end
            local foundKey = KEY_NAME_LOOKUP[keyName]
            if foundKey then
                local oldKey = Binds[action]
                if oldKey then BindAction[oldKey] = nil end
                Binds[action] = foundKey
                BindAction[foundKey] = action
            end
        end
    end
    -- Force Auto Bat bind to H even if an older config had another key saved.
    do
        local oldKey = Binds.AutoBat
        if oldKey then BindAction[oldKey] = nil end
        Binds.AutoBat = Enum.KeyCode.H
        BindAction[Enum.KeyCode.H] = "AutoBat"
    end
    if data.invisSettings and type(data.invisSettings) == "table" then
        for k, v in pairs(data.invisSettings) do
            InvisSettings[k] = v
        end
    end
    return data
end

task.spawn(function()
    while true do
        task.wait(2)
        if configSaveQueued then
            configSaveQueued = false
            pcall(saveConfig)
        end
    end
end)

