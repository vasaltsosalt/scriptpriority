local function Round(p, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r)
    c.Parent = p
    return c
end

local function Stroke(p, t, c, tr)
    local s = Instance.new("UIStroke")
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Thickness = t or 1
    s.Color = c or HAZE.STROKE
    s.Transparency = tr or 0.5
    s.Parent = p

    local g = Instance.new("UIGradient")
    g.Color = PURPLE_STROKE_COLORS
    g.Rotation = 45
    g.Parent = s
    PURPLE_STROKE_GRADS[#PURPLE_STROKE_GRADS + 1] = g

    return s
end

local function Gradient(parent, colors, rotation)
    local g = Instance.new("UIGradient", parent)
    g.Color = ColorSequence.new(colors)
    g.Rotation = rotation or 0
    return g
end

local function TextGradient(label, colors, rotation)
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    local g = Instance.new("UIGradient")
    g.Color = ColorSequence.new(colors)
    g.Rotation = rotation or 0
    g.Parent = label
    return g
end

local function CoolTextGradient(label)
    local g = TextGradient(label, {
        ColorSequenceKeypoint.new(0, HAZE.ACCENT),
        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(255, 255, 255)),
        ColorSequenceKeypoint.new(1, HAZE.ACCENT),
    }, 0)
    COOL_TEXT_GRADS[#COOL_TEXT_GRADS + 1] = g
    return g
end

local function CoolText(label, transparency)
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.TextTransparency = transparency or label.TextTransparency
    return CoolTextGradient(label)
end

