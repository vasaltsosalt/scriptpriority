-- ========== ADIDAS COMMUNITY ANIMATIONS ON EXECUTE ==========
do
    -- Humanoid:ApplyDescription is server-only in this game, so this uses a client-side Animate patch.
    -- Local-only client Animate patch using the real raw animation clip IDs inside the adidas Community bundle assets.
    local ADIDAS_COMMUNITY_CLIMB = "rbxassetid://88763136693023"
    local ADIDAS_COMMUNITY_FALL = "rbxassetid://98600215928904"
    local ADIDAS_COMMUNITY_IDLE = "rbxassetid://122257458498464"
    local ADIDAS_COMMUNITY_JUMP = "rbxassetid://75290611992385"
    local ADIDAS_COMMUNITY_RUN = "rbxassetid://82598234841035"
    local ADIDAS_COMMUNITY_SWIM = "rbxassetid://133308483266208"
    local ADIDAS_COMMUNITY_WALK = "rbxassetid://122150855457006"

    local ADIDAS_IDS = {
        [ADIDAS_COMMUNITY_CLIMB] = true,
        [ADIDAS_COMMUNITY_FALL] = true,
        [ADIDAS_COMMUNITY_IDLE] = true,
        [ADIDAS_COMMUNITY_JUMP] = true,
        [ADIDAS_COMMUNITY_RUN] = true,
        [ADIDAS_COMMUNITY_SWIM] = true,
        [ADIDAS_COMMUNITY_WALK] = true,
    }

    local function setAnimation(folder, animName, animId)
        local anim = folder and folder:FindFirstChild(animName)
        if anim and anim:IsA("Animation") then
            anim.AnimationId = animId
        end
    end

    local function patchAnimate(character)
        local animate = character and (character:FindFirstChild("Animate") or character:WaitForChild("Animate", 10))
        local humanoid = character and (character:FindFirstChildOfClass("Humanoid") or character:WaitForChild("Humanoid", 10))
        if not animate or not humanoid then return end

        pcall(function()
            setAnimation(animate:FindFirstChild("climb"), "ClimbAnim", ADIDAS_COMMUNITY_CLIMB)
            setAnimation(animate:FindFirstChild("fall"), "FallAnim", ADIDAS_COMMUNITY_FALL)
            setAnimation(animate:FindFirstChild("idle"), "Animation1", ADIDAS_COMMUNITY_IDLE)
            setAnimation(animate:FindFirstChild("idle"), "Animation2", ADIDAS_COMMUNITY_IDLE)
            setAnimation(animate:FindFirstChild("jump"), "JumpAnim", ADIDAS_COMMUNITY_JUMP)
            setAnimation(animate:FindFirstChild("run"), "RunAnim", ADIDAS_COMMUNITY_RUN)
            setAnimation(animate:FindFirstChild("swim"), "Swim", ADIDAS_COMMUNITY_SWIM)
            setAnimation(animate:FindFirstChild("swimidle"), "SwimIdle", ADIDAS_COMMUNITY_SWIM)
            setAnimation(animate:FindFirstChild("walk"), "WalkAnim", ADIDAS_COMMUNITY_WALK)

            -- Stop old default tracks so Animate reloads with the new IDs.
            for _, track in ipairs(humanoid:GetPlayingAnimationTracks()) do
                local anim = track.Animation
                if anim and anim.AnimationId ~= "" and not ADIDAS_IDS[anim.AnimationId] then
                    track:Stop(0.1)
                end
            end

            animate.Disabled = true
            task.wait(0.05)
            animate.Disabled = false
        end)
    end

    local function applyAdidasCommunityAnimations(character)
        if not character then return end
        task.spawn(function()
            -- Some games recreate/overwrite Animate after spawn, so patch a few times.
            for _ = 1, 8 do
                if not character.Parent then return end
                patchAnimate(character)
                task.wait(0.5)
            end
        end)
    end

    task.spawn(function()
        applyAdidasCommunityAnimations(Player.Character or Player.CharacterAdded:Wait())
    end)

    Player.CharacterAdded:Connect(function(character)
        task.wait(0.35)
        applyAdidasCommunityAnimations(character)
    end)
end

-- ========== ANTI DIE BYPASS (always on, no toggle) ==========
do
    local antiDieConn = nil

    local function hookAntiDie(character)
        if not character then return end
        local humanoid = character:FindFirstChildOfClass("Humanoid")
            or character:WaitForChild("Humanoid", 10)
        if not humanoid then return end

        if antiDieConn then
            pcall(function() antiDieConn:Disconnect() end)
            antiDieConn = nil
        end

        antiDieConn = humanoid:GetPropertyChangedSignal("Health"):Connect(function()
            if humanoid.Health <= 0 then
                humanoid.Health = humanoid.MaxHealth
            end
        end)

        if humanoid.Health <= 0 then
            humanoid.Health = humanoid.MaxHealth
        end
    end

    if Player.Character then
        hookAntiDie(Player.Character)
    end

    Player.CharacterAdded:Connect(function(character)
        task.wait(0.1)
        hookAntiDie(character)
    end)

    RunService.Heartbeat:Connect(function()
        local character = Player.Character
        if not character then return end
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        if humanoid and humanoid.Health <= 0 then
            humanoid.Health = humanoid.MaxHealth
        end
    end)
end

