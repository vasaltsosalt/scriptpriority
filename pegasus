    local function turnOffInvis()
        if not animPlaying then
            updateInvisVisual(false)
            return
        end
        local character = Player.Character
        local humanoid = character and character:FindFirstChildOfClass("Humanoid")
        animPlaying = false
        updateInvisVisual(false)
        for _, t in pairs(tracks) do pcall(function() t:Stop() end) end
        tracks = {}
        if connection then connection:Disconnect(); connection = nil end
        disconnectFolderConnections()
        revertClone()
        if humanoid then pcall(function() humanoid:ChangeState(Enum.HumanoidStateType.GettingUp) end) end
    end

    local function turnOnInvis()
        if animPlaying then return end
        local character = Player.Character
        if not character then return end
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        if not humanoid then return end
        animPlaying = true
        updateInvisVisual(true)
        tracks = {}
        removeFolders()
        local success = doClone()

        if success then
            task.wait(0.05)
            animationTrickery()
            local lastSetPosition = nil
            local skipFrames = 5

            connection = RunService.PreSimulation:Connect(function()
                if character and character:FindFirstChild("Humanoid") and character.Humanoid.Health > 0 and oldRoot then
                    local root = character.PrimaryPart or character:FindFirstChild("HumanoidRootPart")
                    if root then
                        if skipFrames > 0 then
                            skipFrames = skipFrames - 1
                            lastSetPosition = nil
                        elseif lastSetPosition then
                            local currentPos = oldRoot.Position
                            local jumpDist = (currentPos - lastSetPosition).Magnitude
                            if jumpDist > 3 and not _G.RecoveryInProgress then
                                lastSetPosition = nil
                                if _G.AutoRecoverLagback then
                                    _G.RecoveryInProgress = true
                                    lastRecoveryTime = tick()
                                    pcall(showInvisLagbackError)
                                    task.spawn(function()
                                        if _G.toggleInvisibleSteal then pcall(_G.toggleInvisibleSteal) end
                                        task.wait(0.5)
                                        if _G.toggleInvisibleSteal then pcall(_G.toggleInvisibleSteal) end
                                        _G.RecoveryInProgress = false
                                    end)
                                elseif tick() - lastRecoveryTime > 1.5 then
                                    lastRecoveryTime = tick()
                                    pcall(showInvisLagbackError)
                                end
                            end
                        end

                        if clone then clone.CanCollide = false end
                        for _, c in pairs(oldRoot:GetChildren()) do
                            if c:IsA("Attachment") or c:IsA("Beam") then c:Destroy() end
                        end

                        local rotAngle = _G.InvisStealAngle or 180
                        local sinkAmount = (_G.SinkSliderValue or 5) * 0.5
                        local cf = root.CFrame - Vector3.new(0, sinkAmount, 0)
                        oldRoot.CFrame = cf * CFrame.Angles(math.rad(rotAngle), 0, 0)
                        oldRoot.AssemblyLinearVelocity = root.AssemblyLinearVelocity
                        oldRoot.CanCollide = false
                        lastSetPosition = oldRoot.Position
                    end
                end
            end)
        else
            animPlaying = false
            updateInvisVisual(false)
        end
    end

    _G.toggleInvisibleSteal = function()
        if animPlaying then
            turnOffInvis()
        else
            turnOnInvis()
        end
    end

    Player.CharacterAdded:Connect(function()
        animPlaying = false
        updateInvisVisual(false)
        if connection then connection:Disconnect(); connection = nil end
        disconnectFolderConnections()
        if oldRoot then pcall(function() oldRoot:Destroy() end); oldRoot = nil end
        if clone then pcall(function() clone:Destroy() end); clone = nil end
    end)

    task.spawn(function()
        local wasStealing = false
        local autoEnabledInvis = false
        task.wait(1)
        while task.wait(0.1) do
            if not InvisSettings.AutoOnSteal then
                wasStealing = false
                autoEnabledInvis = false
            else
                local isStealingNow = Player:GetAttribute("Stealing") == true
                if isStealingNow and not wasStealing then
                    if not invisFeatureActive and _G.toggleInvisibleSteal then
                        task.delay(0.25, function()
                            if Player:GetAttribute("Stealing") and not invisFeatureActive then
                                pcall(_G.toggleInvisibleSteal)
                                autoEnabledInvis = true
                            end
                        end)
                    end
                end
                if not isStealingNow and autoEnabledInvis and invisFeatureActive and _G.toggleInvisibleSteal then
                    pcall(_G.toggleInvisibleSteal)
                    autoEnabledInvis = false
                end
                wasStealing = isStealingNow
            end
        end
    end)
end)



