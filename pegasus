-- ========== LINE TO BASE (Tracer) ==========
function findMyBaseSpawn()
    local plots = workspace:FindFirstChild("Plots")
    if not plots then return nil end
    for _, plot in ipairs(plots:GetChildren()) do
        if isMyPlotByName(plot.Name) then
            local base = plot:FindFirstChild("Base")
            if base then
                local spawn = base:FindFirstChild("Spawn")
                if spawn and spawn:IsA("BasePart") then return spawn end
                local bp = base:FindFirstChildWhichIsA("BasePart")
                if bp then return bp end
            end
            local bp = plot:FindFirstChildWhichIsA("BasePart")
            if bp then return bp end
        end
    end
    return nil
end

function startTracer()
    if tracerBeamFolder then return end
    tracerBeamFolder = Instance.new("Folder", workspace)
    tracerBeamFolder.Name = "PegasusTracers"

    local function updateTracer()
        if not tracerEnabled then
            if tracerCurrentBeam then tracerCurrentBeam.Enabled = false end
            return
        end
        local targetPart = findMyBaseSpawn()
        local char = Player.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if hrp and targetPart then
            if not tracerCurrentAtt0 or tracerCurrentAtt0.Parent ~= hrp then
                if tracerCurrentAtt0 then tracerCurrentAtt0:Destroy() end
                tracerCurrentAtt0 = Instance.new("Attachment", hrp)
            end
            if not tracerCurrentAtt1 or tracerCurrentAtt1.Parent ~= targetPart then
                if tracerCurrentAtt1 then tracerCurrentAtt1:Destroy() end
                tracerCurrentAtt1 = Instance.new("Attachment", targetPart)
            end
            if not tracerCurrentBeam then
                tracerCurrentBeam = Instance.new("Beam", tracerBeamFolder)
                tracerCurrentBeam.FaceCamera = true
                tracerCurrentBeam.Width0 = 0.8
                tracerCurrentBeam.Width1 = 0.8
                tracerCurrentBeam.TextureMode = Enum.TextureMode.Wrap
                tracerCurrentBeam.TextureSpeed = 3
                tracerCurrentBeam.LightEmission = 1
                tracerCurrentBeam.LightInfluence = 0
                tracerCurrentBeam.Transparency = NumberSequence.new({
                    NumberSequenceKeypoint.new(0, 0.05),
                    NumberSequenceKeypoint.new(0.5, 0),
                    NumberSequenceKeypoint.new(1, 0.05),
                })
            end
            tracerCurrentBeam.Attachment0 = tracerCurrentAtt0
            tracerCurrentBeam.Attachment1 = tracerCurrentAtt1
            tracerCurrentBeam.Enabled = true
            tracerCurrentBeam.Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0, Color3.fromRGB(45, 0, 85)),
                ColorSequenceKeypoint.new(0.35, Color3.fromRGB(150, 45, 255)),
                ColorSequenceKeypoint.new(0.5, Color3.fromRGB(255, 255, 255)),
                ColorSequenceKeypoint.new(0.65, Color3.fromRGB(150, 45, 255)),
                ColorSequenceKeypoint.new(1, Color3.fromRGB(45, 0, 85)),
            })
        else
            if tracerCurrentBeam then tracerCurrentBeam.Enabled = false end
        end
    end

    task.spawn(function()
        while tracerEnabled do
            task.wait(0.05)
            updateTracer()
        end
    end)
end

function stopTracer()
    tracerEnabled = false
    if tracerCurrentBeam then tracerCurrentBeam:Destroy(); tracerCurrentBeam = nil end
    if tracerCurrentAtt0 then tracerCurrentAtt0:Destroy(); tracerCurrentAtt0 = nil end
    if tracerCurrentAtt1 then tracerCurrentAtt1:Destroy(); tracerCurrentAtt1 = nil end
    if tracerBeamFolder then tracerBeamFolder:Destroy(); tracerBeamFolder = nil end
end

