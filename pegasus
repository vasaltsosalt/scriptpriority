function doHop()
    local currentId = game.JobId or ""
    if currentId ~= "" then visitedServers[currentId] = tick() end

    local url = "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"
    local ok, result = pcall(function() return HttpService:JSONDecode(game:HttpGet(url)) end)
    if ok and result and result.data then
        for i = 1, math.min(8, #result.data) do
            local server = result.data[i]
            if server and server.id and server.id ~= currentId then
                pcall(function()
                    TeleportService:TeleportToPlaceInstance(game.PlaceId, server.id, Player)
                end)
                break
            end
        end
    end

    -- Clean up entries older than 5 minutes
    task.delay(1, function()
        local now = tick()
        for id, ts in pairs(visitedServers) do
            if now - ts > 300 then visitedServers[id] = nil end
        end
    end)
