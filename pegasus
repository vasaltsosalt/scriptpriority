local NO_BIND_BADGE = { PlayerESP = true, Tracer = true, AntiEffect = true, FPSBoost = true }

local instantStealLockActive = false
local instantStealSnapshot = nil
local INSTANT_STEAL_ALLOWED = {
    AutoLeave = true,
    PlayerESP = true,
    Tracer = true,
    StealSpeed = true,
}

local function isAllowedDuringInstantSteal(actionName)
    return INSTANT_STEAL_ALLOWED[actionName] == true
end

local function enforceInstantStealLock()
    -- Turn off every non-allowed system at the source, even if its UI toggle was not synced.
    if infJumpActive then infJumpActive = false; pcall(stopInfJump) end
    if antiRagdollEnabled then antiRagdollEnabled = false; pcall(stopAntiRagdollV2) end
    if antiEffectEnabled then antiEffectEnabled = false; pcall(stopAntiEffect) end
    if autoBatEnabled then autoBatEnabled = false; pcall(stopAutoBat) end
    if autoStealEnabled then autoStealEnabled = false; pcall(stopAutoSteal) end
    if autoJoinerEnabled then autoJoinerEnabled = false; pcall(stopAutoJoiner) end
    if autoTurretEnabled then autoTurretEnabled = false; pcall(stopAutoTurret) end
    if carpetSpeedEnabled then
        carpetSpeedEnabled = false
        if carpetSpeedConn then carpetSpeedConn:Disconnect(); carpetSpeedConn = nil end
    end
    if invisFeatureActive and _G.toggleInvisibleSteal then
        pcall(_G.toggleInvisibleSteal)
    end
    if InvisPanelRefs and InvisPanelRefs.enabledRow and InvisPanelRefs.enabledRow.Set then
        pcall(InvisPanelRefs.enabledRow.Set, false, true, true)
    end

    for actionName, state in pairs(buttonStates) do
        if state and state.isToggle and not isAllowedDuringInstantSteal(actionName) then
            state.setState(false, true)
        end
    end
    queueSaveConfig()
end

local function captureInstantStealSnapshot()
    local snapshot = {
        toggles = {},
        invisFeatureActive = invisFeatureActive == true,
    }
    for actionName, state in pairs(buttonStates) do
        if state and state.isToggle and state.getState then
            snapshot.toggles[actionName] = state.getState() == true
        end
    end
    return snapshot
end

local function enableInstantStealLock()
    if not instantStealLockActive then
        instantStealSnapshot = captureInstantStealSnapshot()
    end
    instantStealLockActive = true
    enforceInstantStealLock()
    notify("Instant Steal", "Only Auto Leave, ESP, Line to Base and Steal Speed can stay on", "warn")
end

local function disableInstantStealLock()
    local snapshot = instantStealSnapshot
    instantStealLockActive = false
    if snapshot and snapshot.toggles then
        for actionName, state in pairs(buttonStates) do
            if state and state.isToggle and state.setState then
                state.setState(snapshot.toggles[actionName] == true, true)
            end
        end
    end
    if snapshot and snapshot.invisFeatureActive and not invisFeatureActive and InvisPanelRefs and InvisPanelRefs.enabledRow and InvisPanelRefs.enabledRow.Set then
        pcall(InvisPanelRefs.enabledRow.Set, true, true, true)
    elseif snapshot and not snapshot.invisFeatureActive and invisFeatureActive and InvisPanelRefs and InvisPanelRefs.enabledRow and InvisPanelRefs.enabledRow.Set then
        pcall(InvisPanelRefs.enabledRow.Set, false, true, true)
    end
    instantStealSnapshot = nil
    queueSaveConfig()
    notify("Instant Steal", "Previous functions restored", "success")
end

